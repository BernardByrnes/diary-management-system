generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  EXECUTIVE_DIRECTOR
  MANAGER
  OWNER
}

enum ExpenseCategory {
  SALARIES
  MEALS
  RENT
  TRANSPORT
  UTILITIES
  MAINTENANCE
  MISCELLANEOUS
}

enum PaymentMethod {
  CASH
  BANK
}

enum RecipientType {
  SUPPLIER
  OWNER
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  CALCULATED
  APPROVED
  PAID
}

enum DistributionStatus {
  CALCULATED
  APPROVED
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  RENT_DUE
  MISSING_READINGS
  BANKING_DISCREPANCY
  TRANSFER_PENDING
  READING_OUT_OF_RANGE
  ADVANCE_LIMIT
  SNAPSHOT_PENDING
  SPOILAGE_PENDING
  REPORT_SHARED
}

enum SnapshotStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationUrgency {
  LOW
  MEDIUM
  HIGH
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  fullName            String
  phone               String   @unique
  password            String
  role                Role
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  managedBranches      BranchManager[]
  ownedBranches        Branch[]            @relation("BranchOwner")
  recordedSupplies     MilkSupply[]        @relation("SupplyRecorder")
  recordedSales        Sale[]              @relation("SaleRecorder")
  recordedExpenses     Expense[]           @relation("ExpenseRecorder")
  flaggedExpenses      Expense[]           @relation("ExpenseFlagged")
  recordedAdvances     Advance[]           @relation("AdvanceRecorder")
  ownerAdvances        Advance[]           @relation("OwnerAdvance")
  requestedTransfers   MilkTransfer[]      @relation("TransferRequester")
  approvedTransfers    MilkTransfer[]      @relation("TransferApprover")
  recordedDeposits     BankDeposit[]       @relation("DepositRecorder")
  recordedReadings     LactometerReading[] @relation("ReadingRecorder")
  profitDistributions  ProfitDistribution[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  recordedSnapshots    StockSnapshot[]     @relation("SnapshotRecorder")
  reviewedSnapshots    StockSnapshot[]     @relation("SnapshotReviewer")
  reportedSpoilages    MilkSpoilage[]      @relation("SpoilageReporter")
  reviewedSpoilages    MilkSpoilage[]      @relation("SpoilageReviewer")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String
  isActive  Boolean  @default(true)
  ownerId   String
  /// ANNUAL | BI_ANNUAL — how often rent is paid for this branch; null = use org default in settings
  rentCycle     String?
  /// Date rent coverage expires — set when ED records a RENT expense
  rentPaidUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner               User                @relation("BranchOwner", fields: [ownerId], references: [id])
  managers            BranchManager[]
  milkSupplies        MilkSupply[]
  sales               Sale[]
  expenses            Expense[]
  bankDeposits        BankDeposit[]
  lactometerReadings  LactometerReading[]
  outgoingTransfers   MilkTransfer[]      @relation("SourceBranch")
  incomingTransfers   MilkTransfer[]      @relation("DestinationBranch")
  advances            Advance[]
  profitDistributions ProfitDistribution[]
  stockSnapshots      StockSnapshot[]
  spoilages           MilkSpoilage[]
}

model BranchManager {
  id         String   @id @default(cuid())
  branchId   String
  managerId  String
  assignedAt DateTime @default(now())

  branch  Branch @relation(fields: [branchId], references: [id])
  manager User   @relation(fields: [managerId], references: [id])

  @@unique([branchId, managerId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milkSupplies MilkSupply[]
  advances     Advance[]
  payments     SupplierPayment[]
}

model MilkSupply {
  id                  String   @id @default(cuid())
  date                DateTime
  liters              Decimal  @db.Decimal(10, 1)
  costPerLiter        Decimal  @db.Decimal(10, 2)
  totalCost           Decimal  @db.Decimal(12, 2)
  /// ED-set selling price for this delivery batch at this branch (used as default for new sales; past sales stay fixed).
  retailPricePerLiter Decimal? @db.Decimal(10, 2)
  /// Optional supplier delivery note / GRN number for traceability.
  deliveryReference   String?
  branchId            String
  supplierId          String
  recordedById        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  branch     Branch   @relation(fields: [branchId], references: [id])
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  recordedBy User     @relation("SupplyRecorder", fields: [recordedById], references: [id])
  sales      Sale[]
}

model Sale {
  id            String   @id @default(cuid())
  date          DateTime
  litersSold    Decimal  @db.Decimal(10, 1)
  pricePerLiter Decimal  @db.Decimal(10, 2)
  revenue       Decimal  @db.Decimal(12, 2)
  branchId      String
  /// Which delivery batch this sale priced against (optional; actual revenue is always liters × price on this row).
  milkSupplyId  String?
  recordedById  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch      @relation(fields: [branchId], references: [id])
  milkSupply MilkSupply? @relation(fields: [milkSupplyId], references: [id])
  recordedBy User        @relation("SaleRecorder", fields: [recordedById], references: [id])
}

model Expense {
  id               String          @id @default(cuid())
  date             DateTime
  category         ExpenseCategory
  description      String
  amount           Decimal         @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  receiptReference String?
  isFlagged        Boolean         @default(false)
  flaggedById      String?
  flaggedAt        DateTime?
  branchId         String
  recordedById     String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User   @relation("ExpenseRecorder", fields: [recordedById], references: [id])
  flaggedBy  User?  @relation("ExpenseFlagged", fields: [flaggedById], references: [id])
}

model Advance {
  id             String        @id @default(cuid())
  recipientType  RecipientType
  amount         Decimal       @db.Decimal(12, 2)
  date           DateTime
  purpose        String
  isDeducted     Boolean       @default(false)
  deductedAt     DateTime?
  deductedFromId String?
  supplierId     String?
  ownerId        String?
  branchId       String?
  recordedById   String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  owner      User?     @relation("OwnerAdvance", fields: [ownerId], references: [id])
  branch     Branch?   @relation(fields: [branchId], references: [id])
  recordedBy User      @relation("AdvanceRecorder", fields: [recordedById], references: [id])
}

model MilkTransfer {
  id                  String         @id @default(cuid())
  date                DateTime
  liters              Decimal        @db.Decimal(10, 1)
  costPerLiter        Decimal        @db.Decimal(10, 2)
  reason              String
  status              TransferStatus @default(PENDING)
  sourceBranchId      String
  destinationBranchId String
  requestedById       String
  approvedById        String?
  approvedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  sourceBranch      Branch @relation("SourceBranch", fields: [sourceBranchId], references: [id])
  destinationBranch Branch @relation("DestinationBranch", fields: [destinationBranchId], references: [id])
  requestedBy       User   @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedBy        User?  @relation("TransferApprover", fields: [approvedById], references: [id])
}

model MilkSpoilage {
  id           String         @id @default(cuid())
  date         DateTime
  liters       Decimal        @db.Decimal(10, 1)
  reason       String
  status       TransferStatus @default(PENDING)
  branchId     String
  reportedById String
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  reportedBy User   @relation("SpoilageReporter", fields: [reportedById], references: [id])
  reviewedBy User?  @relation("SpoilageReviewer", fields: [reviewedById], references: [id])
}

model BankDeposit {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Decimal  @db.Decimal(12, 2)
  bankName        String
  referenceNumber String
  branchId        String
  recordedById    String
  hasDiscrepancy  Boolean  @default(false)
  discrepancyNote String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User   @relation("DepositRecorder", fields: [recordedById], references: [id])
}

model LactometerReading {
  id           String   @id @default(cuid())
  date         DateTime
  time         String
  readingValue Decimal  @db.Decimal(5, 3)
  notes        String?
  branchId     String
  recordedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User   @relation("ReadingRecorder", fields: [recordedById], references: [id])
}

model SupplierPayment {
  id                String        @id @default(cuid())
  supplierId        String
  periodStart       DateTime
  periodEnd         DateTime
  grossAmount       Decimal       @db.Decimal(12, 2)
  advanceDeductions Decimal       @db.Decimal(12, 2)
  netAmount         Decimal       @db.Decimal(12, 2)
  paidAmount        Decimal       @default(0) @db.Decimal(12, 2)
  status            PaymentStatus @default(CALCULATED)
  scheduledDate     DateTime?
  paidAt            DateTime?
  paymentMethod     String?
  paymentReference  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, periodStart, periodEnd])
}

model ProfitDistribution {
  id                String             @id @default(cuid())
  branchId          String
  ownerId           String
  periodStart       DateTime
  periodEnd         DateTime
  totalRevenue      Decimal            @db.Decimal(12, 2)
  totalMilkCosts    Decimal            @db.Decimal(12, 2)
  totalExpenses     Decimal            @db.Decimal(12, 2)
  grossProfit       Decimal            @db.Decimal(12, 2)
  advanceDeductions Decimal            @db.Decimal(12, 2)
  netPayout         Decimal            @db.Decimal(12, 2)
  status            DistributionStatus @default(CALCULATED)
  approvedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  owner  User   @relation(fields: [ownerId], references: [id])

  @@unique([branchId, ownerId, periodStart, periodEnd])
}

model Notification {
  id                String              @id @default(cuid())
  type              NotificationType
  title             String
  message           String
  urgency           NotificationUrgency
  isRead            Boolean             @default(false)
  userId            String
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String
  userId     String
  changes    Json?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])
}

model StockSnapshot {
  id             String         @id @default(cuid())
  date           DateTime
  branchId       String
  /// Liters the manager physically counted on the shelf / in the fridges.
  physicalLiters Decimal        @db.Decimal(10, 1)
  /// System-computed stock at the moment this snapshot was submitted.
  computedLiters Decimal        @db.Decimal(10, 1)
  /// physicalLiters − computedLiters (positive = surplus, negative = shortage).
  varianceLiters Decimal        @db.Decimal(10, 1)
  status         SnapshotStatus @default(PENDING)
  notes          String?
  recordedById   String
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User   @relation("SnapshotRecorder", fields: [recordedById], references: [id])
  reviewedBy User?  @relation("SnapshotReviewer", fields: [reviewedById], references: [id])
}

model SystemSettings {
  id                       String   @id @default("singleton")
  organizationName         String   @default("Bwera Farmers Cooperative")
  currencySymbol           String   @default("UGX")
  financialYearStartMonth  Int      @default(1)
  lactometerMin            Decimal  @default(1.026) @db.Decimal(5, 3)
  lactometerMax            Decimal  @default(1.032) @db.Decimal(5, 3)
  minReadingsPerWeek       Int      @default(2)
  advanceWarningThreshold  Decimal  @default(500000) @db.Decimal(12, 2)
  discrepancyThreshold     Decimal  @default(5000) @db.Decimal(12, 2)
  /// Max absolute variance (liters) before a stock snapshot needs ED approval instead of auto-approving.
  stockVarianceThreshold   Decimal  @default(5.0) @db.Decimal(10, 1)
  customExpenseCategories  Json     @default("[]")
  /// [{ "date": "YYYY-MM-DD", "name": "Eid al-Fitr" }, ...] — movable holidays (Eid) updated each year
  publicHolidays           Json     @default("[]")
  /// Default rent payment rhythm for branches that do not override (ANNUAL | BI_ANNUAL)
  defaultRentCycle         String   @default("ANNUAL")
  updatedAt                DateTime @updatedAt
}
